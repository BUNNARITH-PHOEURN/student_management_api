<%- include('partials/header') %>

        <h1><%= title %></h1>

        <form id="editForm" class="form-card">
            <input type="hidden" id="teacherId" value="<%= teacher.id %>">
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" value="<%= teacher.name %>" required>
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="<%= teacher.email %>" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" value="<%= teacher.password || '' %>" required>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Update Teacher</button>
                <button type="button" id="backButton" class="btn btn-secondary">Back</button>
            </div>
        </form>

    <script>
        document.getElementById('editForm').addEventListener('submit', function(e) {
            e.preventDefault();

            var id = document.getElementById('teacherId').value;
            var name = document.getElementById('name').value.trim();
            var email = document.getElementById('email').value.trim();
            var password = document.getElementById('password').value;

            if (!name || !email || !password) {
                alert('Name, Email, and Password are required.');
                return;
            }

            fetch('/teachers/' + id, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: name, email: email, password: password })
            })
            .then(function(res) {
                if (res.ok) {
                    window.location.href = '/teachers';
                } else {
                    return res.json().then(function(data) { alert(data.error || 'Error updating teacher.'); });
                }
            })
            .catch(function(err) { alert('Request failed: ' + err); });
        });

        document.getElementById('backButton').addEventListener('click', function() {
            window.location.href = '/teachers';
        });
    </script>

<%- include('partials/footer') %>
