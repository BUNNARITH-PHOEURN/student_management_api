<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= typeof title !=='undefined' ? title : 'Student Management' %>
    </title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>

<body>
    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-top">
                <a href="/courses" class="nav-brand">
                    <span class="brand-mark">SM</span>
                    <span class="brand-text">Student Mgt.</span>
                </a>
            </div>

            <nav class="sidebar-nav">
                <a href="/courses" class="nav-link" data-path="/courses">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    </svg>
                    <span class="link-text">Courses</span>
                </a>
                <a href="/students" class="nav-link" data-path="/students">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="8.5" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    <span class="link-text">Students</span>
                </a>
            </nav>

            <div class="sidebar-bottom">
                <a href="/login" id="btn-login" class="nav-link" style="display:none">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                        <polyline points="10 17 15 12 10 7"></polyline>
                        <line x1="15" y1="12" x2="3" y2="12"></line>
                    </svg>
                    <span class="link-text">Login</span>
                </a>

                <div class="sidebar-divider"></div>

                <div class="sidebar-profile" id="profileToggle">
                    <div class="avatar" title="Profile">SM</div>
                    <div class="profile-info link-text">
                        <span class="profile-name">Admin</span>
                    </div>
                    <svg class="profile-chevron link-text" width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </div>

                <div class="profile-menu" id="profileMenu">
                    <button id="btn-logout" class="nav-link btn-logout">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                            <polyline points="16 17 21 12 16 7"></polyline>
                            <line x1="21" y1="12" x2="9" y2="12"></line>
                        </svg>
                        <span class="link-text">Logout</span>
                    </button>
                </div>
            </div>
        </aside>

        <div class="container">
            <script src="/javascripts/header.js" defer></script>
